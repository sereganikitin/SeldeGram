node_modules/
package-lock.json
src-tauri/target/
src-tauri/gen/

# Sidecar binaries (sing-box ~17 MB) — пользователь скачивает руками.
# Инструкция в src-tauri/binaries/README.md.
src-tauri/binaries/*.exe
src-tauri/binaries/sing-box*

# Root .gitignore excludes "dist/" globally — but desktop/dist/ is our
# hand-written splash, not a build output. Un-ignore it here.
!dist/
!dist/**
