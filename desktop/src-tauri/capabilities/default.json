{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for CraboGram desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:webview:default",
    "core:webview:allow-internal-toggle-devtools",
    "allow-hide-window",
    "allow-show-window",
    "allow-toggle-window",
    "allow-minimize-window",
    "allow-toggle-maximize-window",
    "allow-is-maximized-window",
    "allow-start-dragging-window",
    "allow-quit-app",
    "allow-set-unread-count",
    "allow-vpn-list-profiles",
    "allow-vpn-import-link",
    "allow-vpn-import-json",
    "allow-vpn-delete-profile",
    "allow-vpn-connect",
    "allow-vpn-disconnect",
    "allow-vpn-status",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/sing-box", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        { "name": "binaries/sing-box", "sidecar": true, "args": true }
      ]
    }
  ]
}
