{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SeldeGram",
  "version": "1.0.0",
  "identifier": "ru.infoseledka.seldegram.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SeldeGram",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#fff5f9",
        "shadow": true,
        "windowEffects": {
          "effects": ["mica", "acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "SeldeGram E2EE messenger",
    "longDescription": "SeldeGram — защищённый мессенджер.",
    "copyright": "© SeldeGram",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
