{
  "expo": {
    "name": "CraboGram",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff5f9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.infoseledka.seldegram",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "CraboGram использует микрофон во время голосовых звонков и голосовых сообщений.",
        "NSCameraUsageDescription": "CraboGram использует камеру для видеозвонков и загрузки фото."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffd4e1"
      },
      "edgeToEdgeEnabled": false,
      "package": "ru.infoseledka.seldegram",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "11f00aa2-3763-4b54-857d-52093def981e"
      }
    },
    "owner": "seldegram",
    "plugins": [
      "expo-video",
      "expo-secure-store",
      "@config-plugins/react-native-webrtc"
    ]
  }
}
