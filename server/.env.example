PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://seldegram:seldegram_dev_password@localhost:5432/seldegram

REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=https://media.infoseledka.ru
S3_ACCESS_KEY=seldegram
S3_SECRET_KEY=seldegram_dev_password
S3_BUCKET=seldegram-media
S3_REGION=us-east-1

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seldegram.local

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# AI features (translate / summarize via Claude)
ANTHROPIC_API_KEY=

